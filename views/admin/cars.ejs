<%- include('../partials/header') %>

<div class="page-title">
  <div>
    <h1>Manage Cars</h1>
    <p>Add, edit, delete, upload images, and search car listings.</p>
  </div>
  <a class="button" href="/admin/cars/new">Add Car</a>
</div>

<form class="filters" method="GET" action="/admin/cars">
  <input name="q" placeholder="Brand or model" value="<%= query.q || '' %>">
  <input name="location" placeholder="Location" value="<%= query.location || '' %>">
  <select name="fuel_type">
    <option value="">Fuel</option>
    <% ['Petrol', 'Diesel', 'CNG', 'Electric'].forEach((fuel) => { %>
      <option value="<%= fuel %>" <%= query.fuel_type === fuel ? 'selected' : '' %>><%= fuel %></option>
    <% }) %>
  </select>
  <select name="status">
    <option value="">Status</option>
    <option value="available" <%= query.status === 'available' ? 'selected' : '' %>>Available</option>
    <option value="unavailable" <%= query.status === 'unavailable' ? 'selected' : '' %>>Unavailable</option>
  </select>
  <button type="submit">Search</button>
</form>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Image</th>
        <th>Car</th>
        <th>Details</th>
        <th>Price</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% cars.forEach((car) => { %>
        <tr>
          <td>
            <% if (car.image_url) { %>
              <img class="thumb" src="<%= car.image_url %>" alt="<%= car.brand %> <%= car.model %>">
            <% } else { %>
              No image
            <% } %>
          </td>
          <td><strong><%= car.brand %> <%= car.model %></strong><br><%= car.location %></td>
          <td><%= car.year %> - <%= car.fuel_type %> - <%= car.seats %> seats</td>
          <td>Rs. <%= car.price_per_day %>/day</td>
          <td><span class="badge <%= car.status %>"><%= car.status %></span></td>
          <td class="actions">
            <a href="/admin/cars/<%= car.id %>/edit">Edit</a>
            <form action="/admin/cars/<%= car.id %>?_method=DELETE" method="POST" class="inline">
              <button type="submit" onclick="return confirm('Delete this car?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!cars.length) { %>
        <tr><td colspan="6">No cars found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
