<%- include('../partials/header') %>

<div class="page-title">
  <div>
    <h1>Available Cars</h1>
    <p>Search and request the car that fits your trip.</p>
  </div>
</div>

<form class="filters" method="GET" action="/customer/cars">
  <input name="q" placeholder="Brand or model" value="<%= query.q || '' %>">
  <input name="location" placeholder="Location" value="<%= query.location || '' %>">
  <select name="fuel_type">
    <option value="">Fuel</option>
    <% ['Petrol', 'Diesel', 'CNG', 'Electric'].forEach((fuel) => { %>
      <option value="<%= fuel %>" <%= query.fuel_type === fuel ? 'selected' : '' %>><%= fuel %></option>
    <% }) %>
  </select>
  <input type="number" name="seats" placeholder="Min seats" value="<%= query.seats || '' %>">
  <input type="number" name="max_price" placeholder="Max price" value="<%= query.max_price || '' %>">
  <button type="submit">Search</button>
</form>

<div class="cards">
  <% cars.forEach((car) => { %>
    <article class="card">
      <% if (car.image_url) { %>
        <img class="car-image" src="<%= car.image_url %>" alt="<%= car.brand %> <%= car.model %>">
      <% } %>
      <h2><%= car.brand %> <%= car.model %></h2>
      <p><%= car.year %> - <%= car.fuel_type %> - <%= car.seats %> seats</p>
      <p><%= car.location %></p>
      <p class="price">Rs. <%= car.price_per_day %>/day</p>
      <p><%= car.description || '' %></p>
      <a class="button" href="/customer/cars/<%= car.id %>/book">Book</a>
    </article>
  <% }) %>
  <% if (!cars.length) { %>
    <p class="empty">No cars match your search.</p>
  <% } %>
</div>

<%- include('../partials/footer') %>
